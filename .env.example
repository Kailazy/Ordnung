# Template for the local .env (which is gitignored). Copy this file to `.env`
# and fill in the value, or set the variable in your shell instead.
#
#   cp .env.example .env
#
# Ordnung loads `.env` from the repo root on startup (cargo run / make run), so
# the token is available without exporting it in the shell. A token saved in the
# GUI Settings window (~/.ordnung/config.toml) takes priority over this; the env
# var is the fallback, mainly for dev launches and the CLI.

# Discogs personal access token: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=

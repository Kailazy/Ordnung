/target
**/*.rs.bk
Cargo.lock.orig

# Local catalog/test artifacts — do not commit the user's audio or DBs.
/testdata/*.db
/testdata/*.db-*
/testdata/seeker-sample/
*.db-wal
*.db-shm

# macOS cruft
.DS_Store

# Built app bundle + DMG — regenerate with tools/build-app.sh
/Ordnung.app/
/Ordnung.dmg
/tools/.app-build/
/tools/.dmg-build/

# Local secrets — Discogs token etc. The committed .env.example is the template.
/.env
/.env.*
!/.env.example

# Local-only Claude Code state
/CLAUDE.md
/.claude/settings.local.json
/.claude/scheduled_tasks.lock
